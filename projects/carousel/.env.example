# Copy this file to ".env" and fill in keys to generate REAL slides.
# With NO keys, the pipeline runs free in stub mode (placeholder SVG slides).

# --- Keys (optional) ---
ANTHROPIC_API_KEY=
FAL_KEY=

# --- Provider selection (provider:model) — swap models without code changes ---
# FOUNDRY_LLM=anthropic:claude-sonnet-4-6
# FOUNDRY_IMAGE=fal:openai/gpt-image-2
# FOUNDRY_IMAGE=fal:fal-ai/nano-banana
# FOUNDRY_IMAGE=fal:fal-ai/flux/dev

# --- Other ---
# FOUNDRY_NUM_SLIDES=6
# FOUNDRY_STUB=1     # force free offline mode even if keys are set
